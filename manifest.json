{
  "manifest_version": 3,
  "name": "theCoderSchool AI Notes+",
  "version": "1.0",
  "description": "Uses AI to generate lesson notes in a popup",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "theCoderSchool AI Generator"
  },
  "content_scripts": [
    {
      "matches": [
        "https://server.thecoderschool.com/notes/writeNote.php*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}